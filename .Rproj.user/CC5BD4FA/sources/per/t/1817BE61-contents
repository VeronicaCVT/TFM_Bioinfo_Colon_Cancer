## 2. Carga y Preparación de Datos ####

# Carga de la matriz de conteos
data <- read.table("Data/GSE92914/GSE92914_raw_counts_GRCh38.p13_NCBI.tsv", header = TRUE, row.names = 1)
rownames(data) <- as.character(rownames(data))
head(data)
dim(data)

# Carga de metadata
meta <- read.csv("Data/GSE92914/GSE92914_full_metadata.csv", header = TRUE)
rownames(meta) <- meta$X
head(meta)
dim(meta)

# Generar metadata (coldata) extrayendo información de los nombres de muestra
coldata <- data.frame(
  Condition = substr(meta$title, nchar(meta$title) - 1, nchar(meta$title)),
  Patient = substr(meta$title, nchar(meta$title) - 3, nchar(meta$title) - 3),
  row.names = rownames(meta)
)

# Mantener solo las filas que NO son NM
coldata <- coldata[coldata$Condition != "NM", ]
coldata$Condition <- as.factor(coldata$Condition)
coldata$Condition <- droplevels(coldata$Condition)
levels(coldata$Condition)

coldata$Patient <- as.factor(coldata$Patient)
levels(coldata$Patient)

# Ajustar el data para que sea compatible con metadata
data <- data[, rownames(coldata)]

# Relevel para que Normal (normal colon) sea la referencia basal
coldata$Condition <- relevel(coldata$Condition, ref = "PN")

# Check de seguridad: comprobar que nombres de conteos y metadata coinciden
all(rownames(coldata) == colnames(data))
head(coldata)
str(coldata)

