# 6.3 PCA (Análisis de Componentes Principales)

# Filtrar muestras_LM, solo queremos ver PN vs MT
muestras_sin_LM <- colData(dds)$Condition %in% c("PN", "MT")
rld_sin_LM <- rld[, muestras_sin_LM]
colData(rld_sin_LM)$Condition <- droplevels(colData(rld_sin_LM)$Condition)

# PCA con los top 1500 genes más variables
pca_plot1500 <- plotPCA(rld_sin_LM, intgroup = c("Condition"), ntop=1500) + 
  scale_color_manual(values = c("PN" = "#00A087", "MT" = "#F39B7F"),
                     labels = c("Normal (PN)", "Tumor (MT)")) +
  labs(title = NULL,
