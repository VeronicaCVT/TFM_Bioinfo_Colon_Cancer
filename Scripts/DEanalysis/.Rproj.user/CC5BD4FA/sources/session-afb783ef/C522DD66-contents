### **3.10. Clusterización no jerárquica: K-means** ####

matrix.dist <- dist(data_numerico_scaled)

set.seed(2002)

n_clases <- length(unique(data$classification))   # CUIDADO IMPORTANTE CAMBIAR SEGUN SEA NECESARIO
km_resultados <- kmeans(data_numerico_scaled, centers = n_clases, nstart = 25)

table(Cluster = km_resultados$cluster,  # Si el algoritmo es perfecto, se ven nuemros altos solo en la diagonal de la tabla.
      Diagnostico_Real = data$classification)  # CUIDADO IMPORTANTE CAMBIAR SEGUN SEA NECESARIO 

data_plot <- data.frame(
  PC1 = pca.results$x[, 1], 
  PC2 = pca.results$x[, 2], 
  Cluster = as.factor(km_resultados$cluster), 
  Diagnostico = data$classification   # CUIDADO IMPORTANTE CAMBIAR SEGUN SEA NECESARIO
)

ggplot(data_plot, 
       aes(x = PC1, 
           y = PC2, 
           color = Cluster,      # El color representa el grupo asignado por K-means
