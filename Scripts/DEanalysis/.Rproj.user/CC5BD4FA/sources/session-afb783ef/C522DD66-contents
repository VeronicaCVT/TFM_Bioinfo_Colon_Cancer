## **4. Técnicas de Aprendizaje Supervisado** ####

### INCISO PARA EL CORRECTOR

# Me he dado cuenta de que no he hecho los modelos de aprendizaje supervisado con el dataset reducido generado por
# la reducción de dimensionalidad. Hubiese sido tan sencillo como emplear `data.pca.pro` para realizar la partición
# de los datos.

### **4.0. Configuración del Dataset de Análisis** ####

#### PROCEDIMIENTO HABITUAL ####

data$classification <- as.factor(data$classification)   
table(data$classification)   

set.seed(2002)

train_index <- createDataPartition(data$classification,
                                   p = 0.8,
                                   list = FALSE)

train_data <- data[train_index, ]   
test_data  <- data[-train_index, ]  

prop.table(table(train_data$classification))  
prop.table(table(test_data$classification))  

anyNA(train_data) # Debería devolver FALSE

### **4.1. Regularized Discriminant Analysis (RDA)** ####

modelo_rda <- train(classification ~ ., 
                    data = train_data, # CAMBIAR A train_data SI EL ALGORITMO LO CORRE
                    method = "rda", # <--- El cambio clave
                    trControl = trainControl(method = "cv", number = 10),
                    preProcess = c("center", "scale")) 

print(modelo_rda)

predic_rda <- predict(modelo_rda, newdata = test_data) # CAMBIAR A tEST_data SI EL ALGORITMO LO CORRE
confusionMatrix(predic_rda, test_data$classification)   # CAMBIAR A test_data SI EL ALGORITMO LO CORRE


### **4.2. Flexible Discriminant Analysis (FDA)** ####

modelo_fda <- train(classification ~ ., 
                    data = train_data, 
                    method = "fda", # <--- El cambio clave
                    trControl = trainControl(method = "cv", number = 10),
                    preProcess = c("center", "scale")) 

print(modelo_fda)

predic_fda <- predict(modelo_fda, newdata = test_data)
confusionMatrix(predic_fda, test_data$classification)


### **4.3. K-Nearest Neighbors (k-NN)** ####

modelo_knn <- train(classification ~ ., 
                    data = train_data, 
                    method = "knn", # <--- El cambio clave
                    trControl = trainControl(method = "cv", number = 10),
                    preProcess = c("center", "scale")) 

print(modelo_knn)
plot(modelo_knn)   # esto sirve para mirar el numero optimo de grupos

predic_knn <- predict(modelo_knn, newdata = test_data)
confusionMatrix(predic_knn, test_data$classification)


### **4.4. Support Vector Machines (SVM)** ####

modelo_svm <- train(classification ~ .,                    
                    data = train_data,                 
                    method = "svmLinear",   # "svmRadial"      
                    trControl = trainControl(method = "cv", number = 10), 
                    preProcess = c("center", "scale"), 
                    tuneGrid = expand.grid(C = seq(0.1, 2, length = 20)),
                    prob.model = TRUE)               

modelo_svm

plot(modelo_svm)

predic_svm <- predict(modelo_svm, newdata = test_data)
confusionMatrix(predic_svm, test_data$classification)

prob_svm <- predict(modelo_svm, newdata = test_data, type = "prob")


### **4.5. Random Forest (RF)** ####

modelo_rf <- train(classification ~ .,         
                   data = train_data,       
                   method = "rf",          
                   trControl = trainControl(method = "cv", number = 10),
                   tuneLength = 10,       
                   importance = TRUE)       

modelo_rf 

plot(modelo_rf)       

plot(varImp(modelo_rf))

predic_rf <- predict(modelo_rf, newdata = test_data)
confusionMatrix(predic_rf, test_data$classification)


### **4.6. Naive Bayes** ####

modelo_nb <- train(classification ~ ., 
                   data = train_data, 
                   method = "naive_bayes", 
                   trControl = trainControl(method = "cv", number = 10),
                   preProcess = c("center", "scale"),
                   tuneGrid = expand.grid(usekernel = c(TRUE, FALSE), 
                                          laplace = 0, 
                                          adjust = 1))

predic_nb <- predict(modelo_nb, newdata = test_data)
confusionMatrix(predic_nb, test_data$classification)


### **4.7. Gradient Boosting Machines (GBM)** ####

modelo_gbm <- train(classification ~ ., 
                    data = train_data, 
                    method = "gbm", 
                    trControl = trainControl(method = "cv", number = 10),
                    preProcess = c("center", "scale"),
                    verbose = FALSE) # Para que no ensucie el R Markdown

print(modelo_gbm)

predic_gbm <- predict(modelo_gbm, newdata = test_data)
confusionMatrix(predic_gbm, test_data$classification)


## **5. Evaluación del rendimiento y comparativa de modelos predictivos** ####

resultados <- resamples(list(RDA = modelo_rda,
                             FDA = modelo_fda,
                             KNN   = modelo_knn,
                             SVM = modelo_svm,
                             RF    = modelo_rf,
                             NB    = modelo_nb,
                             GBM   = modelo_gbm))

summary(resultados)

dotplot(resultados, 
        main = "Comparativa Global de Modelos Supervisados",
        metric = "Accuracy")























