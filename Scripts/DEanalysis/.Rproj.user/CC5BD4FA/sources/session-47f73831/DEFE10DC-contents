### Principal component analysis (PCA)** ####

varianza_genes <- apply(data, 1, var)  # varianza por FILAS (genes)
data_filtered <- data[varianza_genes > 0.1 & !is.na(varianza_genes),] # Filtrado porque PCA no admite columnas (genes) con todo 0
dim(data_filtered)

pca.results <- prcomp(t(data_filtered),       
                      center=TRUE, 
                      scale.=TRUE) 

data.pca <- data.frame(pca.results$x)

data.pca$Sample <- rownames(data.pca)
data.pca$Class <- substr(data.pca$Sample, 1, 2)
data.pca$Patient <- substr(data.pca$Sample, 3, 3)
str(data.pca)

varianzas <- pca.results$sdev^2
varianza.explicada <- varianzas / sum(varianzas)

