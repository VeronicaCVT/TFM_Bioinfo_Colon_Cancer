## DESeq2 ####

### Data preprocessing ####

coldata <- data.frame(Patient = data.pca$Patient,
                      Condition = data.pca$Class,
                      row.names = colnames(data))
coldata$Patient <- as.factor(coldata$Patient)
coldata$Condition <- as.factor(coldata$Condition)
coldata$Condition <- relevel(coldata$Condition, ref = "PN")
head(coldata)
str(coldata)

all(rownames(coldata) == colnames(data)) # Comprobar que hay consistencia en los nombres

dds <- DESeqDataSetFromMatrix(countData = data,
                              colData = coldata,
                              design= ~ Patient + Condition)
dim(dds)


#### Filtered data ####

smallestGroupSize <- 5
keep <- rowSums(counts(dds) >= 10) >= smallestGroupSize
dds <- dds[keep,]
dim(dds)

### DEseq + results ####

dds <- DESeq(dds)

#### Regularized log transform (rlog) ####

rld <- rlog(dds, blind=FALSE) # Estabilización de la varianza + cpnsistencia en visualización

rld_mat <- assay(rld)

data_long_rlog <- as.data.frame(rld_mat) %>%
  pivot_longer(everything(), names_to = "sample", values_to = "rlog_counts")

