### Log fold change shrinkage for visualization and ranking ####
resLFC <- lfcShrink(dds, coef="Condition_PT_vs_PN", type="apeglm") # No borra genes, recalcula LFC y standar error
resLFC_ordered <- resLFC[order(resLFC$padj), ]
resLFC_ordered
write.csv(as.data.frame(resLFC_ordered),
file = "results/Resultados_LFC_Shrink.csv")
