pca.results <- prcomp(t(data_filtered),
center=TRUE,
scale.=TRUE)
data.pca <- data.frame(pca.results$x)
varianzas <- pca.results$sdev^2
varianza.explicada <- varianzas / sum(varianzas)
varianza.acumulada <- cumsum(varianza.explicada)
n.pc <- min(which(varianza.acumulada > 0.90))
n.pc
ggplot(data.pca,
aes(x=PC1,
y=PC2)) +
geom_point(size=3, alpha=0.7)                  +
scale_color_manual(values=c("#00A087", "#F39B7F")) +
labs(title= "AnĂˇlisis de Componentes Principales (PCA)",
x=paste0(paste('PC1', round(varianza.explicada[1] * 100, 2)), '%'),
y=paste0(paste('PC2', round(varianza.explicada[2] * 100, 2)),'%') +
theme_light() +
theme(panel.grid.major = element_line(color="gray90"),
panel.grid.minor = element_blank(),
panel.background = element_rect(fill = "gray95"),
plot.title = element_text(hjust = 0.5, face = "bold"),
text = element_text(family = "serif", size = 12))
